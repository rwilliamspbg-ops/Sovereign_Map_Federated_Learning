          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(tpm_message_verification_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Message Verify P95",
          "refId": "B"
        }
      ],
      "title": "Verification Latency (P95)",
