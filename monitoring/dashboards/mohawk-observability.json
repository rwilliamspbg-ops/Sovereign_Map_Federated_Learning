        "h": 8,
        "w": 8,
        "x": 8,
        "y": 36
      },
      "id": 14,
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.5, sum by (le) (rate(mohawk_proof_verification_latency_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(mohawk_proof_verification_latency_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "1000 * histogram_quantile(0.99, sum by (le) (rate(mohawk_proof_verification_latency_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
