        "h": 8,
        "w": 8,
        "x": 0,
        "y": 36
      },
      "id": 13,
      "targets": [
        {
          "expr": "100 * (1 - (sum(rate(mohawk_proof_verifications_total{result=\"rejected\"}[5m])) / clamp_min(sum(rate(mohawk_proof_verifications_total[5m])), 0.001)))",
