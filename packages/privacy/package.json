{
  "name": "@sovereignmap/privacy",
  "version": "0.1.0",
  "description": "SGP-001 differential privacy implementation with zk-SNARK proofs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./zk": {
      "import": "./dist/zk.js",
      "types": "./dist/zk.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "npm --prefix ../compression run build",
    "build": "tsc && npm run wasm:copy",
    "wasm:copy": "cp -r src/wasm dist/ 2>/dev/null || true",
    "test": "vitest run",
    "pretest:ci": "npm --prefix ../compression run build",
    "test:ci": "vitest run --coverage",
    "bench": "vitest bench",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sovereignmap/compression": "^1.0.1",
    "eventemitter3": "^5.0.1",
    "libsodium-wrappers": "^0.8.2",
    "ml-matrix": "^6.10.6"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.8.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@webgpu/types": "^0.1.69",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
