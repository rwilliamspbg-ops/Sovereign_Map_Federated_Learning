{
  "name": "@sovereignmap/core",
  "version": "0.1.2",
  "description": "Core Sovereign Map node client with privacy-preserving protocol, BFT consensus, and Island Mode",
  "keywords": [
    "sovereignmap",
    "depin",
    "federated-learning",
    "privacy",
    "bft"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    },
    "./network": {
      "import": "./dist/network.js",
      "types": "./dist/network.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist",
    "wasm",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run wasm:copy",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:targeted": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo",
    "wasm:copy": "cp -r wasm dist/ 2>/dev/null || true"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@grpc/grpc-js": "^1.9.14",
    "@libp2p/tcp": "^11.0.18",
    "@multiformats/multiaddr": "^13.0.1",
    "eventemitter3": "^5.0.1",
    "libp2p": "^3.2.4",
    "nanoid": "^5.1.11",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@sovereignmap/consensus": "^0.1.2",
    "@sovereignmap/island": "^0.1.2",
    "@sovereignmap/privacy": "^0.1.2"
  },
  "peerDependenciesMeta": {
    "@sovereignmap/privacy": {
      "optional": true
    },
    "@sovereignmap/consensus": {
      "optional": true
    },
    "@sovereignmap/island": {
      "optional": true
    }
  }
}
