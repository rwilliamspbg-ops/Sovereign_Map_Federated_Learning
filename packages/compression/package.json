{
  "name": "@sovereignmap/compression",
  "version": "1.0.1",
  "description": "Privacy-aware data compression engine for Sovereign Map federated learning",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest",
    "test:ci": "vitest --run",
    "test:benchmark": "vitest bench",
    "test:integration": "vitest run --include '**/*.integration.test.ts'",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test:ci"
  },
  "keywords": [
    "compression",
    "quantization",
    "privacy",
    "federated-learning",
    "delta-encoding",
    "deflate"
  ],
  "author": "Sovereign Map Contributors",
  "license": "Apache-2.0",
  "dependencies": {
    "eventemitter3": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sovereign-map/sovereign-map-federated-learning.git",
    "directory": "packages/compression"
  },
  "homepage": "https://github.com/sovereign-map/sovereign-map-federated-learning/tree/main/packages/compression#readme"
}
