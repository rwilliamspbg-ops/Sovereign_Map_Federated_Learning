# Incremental Scale Test Configuration
# Sovereign Map Federated Learning

# Test Parameters
INITIAL_NODES=20
INCREMENT_NODES=20
MAX_NODES=100
CONVERGENCE_THRESHOLD=93
TOTAL_ROUNDS=500

# Feature Flags
TPM_ENABLED=true
NPU_ENABLED=true
MONITORING_ENABLED=true
LOGGING_LEVEL=INFO

# Deployment
COMPOSE_FILE=docker-compose.full.yml
DOCKER_BUILD_PARALLEL=4
RESOURCE_LIMITS_ENABLED=true

# Backend Configuration
BACKEND_WORKERS=4
FLASK_ENV=production
DATABASE_CONNECTION_POOL=50

# Monitoring
PROMETHEUS_RETENTION=90d
PROMETHEUS_SCRAPE_INTERVAL=15s
GRAFANA_DASHBOARD_AUTO_SYNC=true
ALERTMANAGER_ENABLED=true

# Performance Tuning
BATCH_SIZE=32
LEARNING_RATE=0.001
MOMENTUM=0.9
WEIGHT_DECAY=0.0001

# TPM Configuration
TPM_CERT_VALIDITY_DAYS=365
TPM_TRUST_CACHE_TTL=3600
TPM_REVOCATION_CHECK_INTERVAL=300

# NPU/GPU Configuration
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.8
ENABLE_MIXED_PRECISION=true

# Data Configuration
DATA_SHARD_SIZE=1000
DATA_SHUFFLE_ENABLED=true
DATA_AUGMENTATION_ENABLED=false

# Byzantine Configuration
BYZANTINE_ATTACK_ENABLED=false
BYZANTINE_FRACTION=0.0
BYZANTINE_ATTACK_TYPE=label_flip

# Privacy Configuration
DIFFERENTIAL_PRIVACY_ENABLED=true
DP_EPSILON=1.0
DP_DELTA=1e-5

# Test Output
RESULTS_DIR=test-results
SAVE_MODELS=true
SAVE_METRICS=true
SAVE_LOGS=true
LOG_RETENTION_DAYS=30

# Cleanup
AUTO_CLEANUP_ON_COMPLETION=false
ARCHIVE_RESULTS=true
COMPRESS_RESULTS=true

# Notifications (optional)
SLACK_WEBHOOK_URL=""
EMAIL_ALERTS_ENABLED=false
EMAIL_RECIPIENTS=""
