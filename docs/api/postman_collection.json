            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_node_id\": 1,\n  \"to_node_id\": 2,\n  \"success\": true,\n  \"signed\": true,\n  \"latency_ms\": 11.2\n}"
            },
            "url": "{{tpmBaseUrl}}/event/message"
          }
        }
      ]
    },
    {
      "name": "Tokenomics Metrics Exporter",
      "item": [
        {
          "name": "GET /health",
          "request": {
