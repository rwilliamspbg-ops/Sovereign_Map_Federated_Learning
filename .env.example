# Environment variables for Sovereign Map
# Copy this to your system and update as needed

# API Keys
GEMINI_API_KEY=

# System Configuration
FLASK_ENV=production
NODE_COUNT=100000
SECRET_KEY=sovereign-federation-secret-key

# Monitoring
PROMETHEUS_PORT=8000
PROMETHEUS_RETENTION=30d

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Database
REDIS_HOST=redis
REDIS_PORT=6379

# 3D Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_PROMETHEUS_URL=http://localhost:9090
VITE_3D_QUALITY=high
VITE_REAL_TIME_UPDATE_INTERVAL=1000
VITE_THREAT_ANALYSIS_ENABLED=true
