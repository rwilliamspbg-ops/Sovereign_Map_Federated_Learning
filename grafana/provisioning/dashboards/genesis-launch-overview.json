{
  "__inputs": [],
  "__requires": [],
  "uid": "genesis-launch-overview",
  "title": "Genesis Launch Overview",
  "description": "🚀 Primary launch dashboard — FL training progress, node participation, accuracy, trust scores, network health — optimized for millions of nodes",
  "tags": [
    "genesis",
    "federated-learning",
    "sovereign-map",
    "enhanced"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "🎯 Model Accuracy",
      "description": "Current global model accuracy - Target > 85%",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 5,
        "h": 5
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#8F3BB8", "value": null},
              {"color": "#FF5733", "value": 50},
              {"color": "#FDB462", "value": 70},
              {"color": "#FFED6F", "value": 80},
              {"color": "#90EE90", "value": 85},
              {"color": "#2ECC40", "value": 92}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "sovereignmap_fl_accuracy",
          "legendFormat": "Accuracy",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "📊 Training Loss",
      "description": "Cross-entropy loss - Target < 0.05",
      "gridPos": {
        "x": 5,
        "y": 0,
        "w": 5,
        "h": 5
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "none",
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#2ECC40", "value": null},
              {"color": "#90EE90", "value": 0.1},
              {"color": "#FFED6F", "value": 0.3},
              {"color": "#FDB462", "value": 0.5},
              {"color": "#FF5733", "value": 1.0}
            ]
          },
          "min": 0,
          "max": 3,
          "decimals": 4
        }
      },
      "targets": [
        {
          "expr": "sovereignmap_fl_loss",
          "legendFormat": "Loss",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "🔄 Current FL Round",
      "description": "Training round counter",
      "gridPos": {
        "x": 10,
        "y": 0,
        "w": 5,
        "h": 5
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#3498DB"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "#3498DB", "value": null}]
          },
          "unit": "short",
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "sovereignmap_fl_round",
          "legendFormat": "Round",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "🌐 Active Nodes",
      "description": "Nodes actively participating this round",
      "gridPos": {
        "x": 15,
        "y": 0,
        "w": 5,
        "h": 5
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#FF5733", "value": null},
              {"color": "#FDB462", "value": 5},
              {"color": "#FFED6F", "value": 50},
              {"color": "#90EE90", "value": 500},
              {"color": "#2ECC40", "value": 5000}
            ]
          },
          "unit": "short",
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "sovereignmap_active_nodes",
          "legendFormat": "Nodes",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "✅ System Health",
      "description": "Overall network health score",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#FF5733", "value": null},
              {"color": "#FDB462", "value": 60},
              {"color": "#FFED6F", "value": 75},
              {"color": "#90EE90", "value": 85},
              {"color": "#2ECC40", "value": 90}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "((sovereignmap_active_nodes / 10) * 100)",
          "legendFormat": "Health",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "📈 Accuracy Convergence",
      "description": "Model accuracy progression over time - Higher is better",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max", "min"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {"mode": "multi"},
        "thresholds": {}
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#2ECC40"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 3,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "never",
            "drawStyle": "line"
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#2ECC40", "value": null},
              {"color": "red", "value": 50}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sovereignmap_fl_accuracy",
          "legendFormat": "Accuracy %",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        },
        {
          "expr": "sovereignmap_fl_accuracy * 0.95",
          "legendFormat": "95% Confidence",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "📉 Loss Minimization",
      "description": "Training loss progression - Lower is better, should asymptote to 0",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "min"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#FF5733"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 3,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "drawStyle": "line"
          },
          "unit": "none",
          "decimals": 4,
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "sovereignmap_fl_loss",
          "legendFormat": "Loss",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "🌐 Node Participation Timeline",
      "description": "Active node count over time - Shows network growth and stability",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 7
      },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max", "mean"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#3498DB"
          },
          "custom": {
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 30,
            "showPoints": "never",
            "drawStyle": "line"
          },
          "unit": "short",
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "sovereignmap_active_nodes",
          "legendFormat": "Active Nodes",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "⚡ Round Duration & Throughput",
      "description": "FL round execution time (p95) and throughput (rounds/min)",
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 7
      },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "mean"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#9B59B6"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "drawStyle": "line"
          },
          "unit": "s",
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(sovereignmap_fl_round_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 Duration (sec)",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "🎯 Convergence Velocity",
      "description": "Rate of accuracy improvement per round - Higher is better during training",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 6
      },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "mean"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#F39C12"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "none",
            "drawStyle": "line"
          },
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#FF5733", "value": null},
              {"color": "#FDB462", "value": 0.0001},
              {"color": "#FFED6F", "value": 0.001},
              {"color": "#90EE90", "value": 0.005},
              {"color": "#2ECC40", "value": 0.01}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(sovereignmap_fl_accuracy[5m])",
          "legendFormat": "Accuracy Δ/sec",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "📊 Total FL Rounds",
      "description": "Cumulative rounds completed",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 6,
        "h": 6
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#9B59B6"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "#9B59B6", "value": null}]
          },
          "unit": "short",
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "sovereignmap_fl_round",
          "legendFormat": "Rounds",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "🏆 Network Status",
      "description": "Overall network operational status",
      "gridPos": {
        "x": 18,
        "y": 20,
        "w": 6,
        "h": 6
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#FF5733", "value": null},
              {"color": "#FDB462", "value": 0.5},
              {"color": "#2ECC40", "value": 0.8}
            ]
          },
          "unit": "percentunit",
          "decimals": 0,
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {"text": "HEALTHY", "color": "#2ECC40"},
                "0": {"text": "FAILED", "color": "#FF5733"}
              }
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "(sovereignmap_active_nodes > 0) ? 1 : 0",
          "legendFormat": "Status",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    }
  ]
}
