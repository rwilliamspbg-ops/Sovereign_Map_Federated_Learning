      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 20.0,
          "decimals": 2,
          "unit": "x",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
