{
  "title": "Sovereign Map | Core Operations HUD",
  "uid": "sovereign-core-hud-001",
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "core",
    "hud",
    "sovereign"
  ],
  "schemaVersion": 38,
  "panels": [
    {
      "type": "row",
      "title": "Neural Intelligence & Distributed Sync",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "title": "FL Global Accuracy (Prometheus Source of Truth)",
      "type": "gauge",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(sovereignmap_fl_accuracy)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100.0,
          "decimals": 2,
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40.0
              },
              {
                "color": "green",
                "value": 80.0
              }
            ]
          }
        }
      },
      "options": {
        "text": {},
        "orientation": "auto"
      }
    },
    {
      "title": "Node Availability (Active / Target %)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(count(up{job=~\"sovereign-nodes|node-agent\"} == 1) / clamp_min(count(up{job=~\"sovereign-nodes|node-agent\"}), 1)) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "title": "Total Completed FL Rounds",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 10,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
