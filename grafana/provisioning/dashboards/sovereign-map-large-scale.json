      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "#2ECC40", "value": null}, {"color": "#90EE90", "value": 50}, {"color": "#FFED6F", "value": 75}, {"color": "#FDB462", "value": 85}, {"color": "#FF5733", "value": 95}]}, "min": 0, "max": 100, "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}, "mappings": []}, "overrides": []},
      "targets": [{"expr": "100 - ((node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
