      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "#FF5733", "value": null}, {"color": "#FDB462", "value": 100}, {"color": "#FFED6F", "value": 1000}, {"color": "#90EE90", "value": 10000}, {"color": "#2ECC40", "value": 100000}]}, "unit": "short", "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}, "mappings": []}, "overrides": []},
