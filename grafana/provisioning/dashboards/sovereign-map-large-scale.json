      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "#F39C12"}, "custom": {"lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "showPoints": "never"}, "unit": "s"}, "overrides": []},
      "targets": [{"expr": "histogram_quantile(0.95, rate(sovereignmap_fl_round_duration_seconds_bucket[5m]))", "legendFormat": "p95 Duration", "refId": "A"}]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "📊 Resource Utilization (Aggregated)",
