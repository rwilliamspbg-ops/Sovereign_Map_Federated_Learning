      "fieldConfig": {"defaults": {"custom": {"lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never"}, "unit": "percent", "min": 0, "max": 100}, "overrides": [{"matcher": {"id": "byName", "options": "Consensus Health"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#2ECC40"}}]}]},
      "targets": [{"expr": "sovereignmap_consensus_health * 100", "legendFormat": "Consensus Health %", "refId": "A"}]
    },
    {
      "id": 11,
      "type": "stat",
