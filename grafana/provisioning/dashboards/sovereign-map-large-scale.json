    {
      "id": 14,
      "type": "stat",
      "title": "🎯 Target Achievement",
      "gridPos": {"x": 18, "y": 20, "w": 6, "h": 4},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "#FF5733", "value": null}, {"color": "#FDB462", "value": 50}, {"color": "#FFED6F", "value": 75}, {"color": "#2ECC40", "value": 90}]}, "unit": "percent", "min": 0, "max": 100, "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}},
      "targets": [{"expr": "(sovereignmap_fl_accuracy / 100) * 100", "refId": "A"}]
