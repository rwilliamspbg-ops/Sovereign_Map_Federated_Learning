      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 7},
      "options": {"legend": {"calcs": ["lastNotNull", "max", "mean"], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "#3498DB"}, "custom": {"lineInterpolation": "stepAfter", "lineWidth": 3, "fillOpacity": 30, "showPoints": "never"}, "unit": "short", "min": 0}, "overrides": []},
      "targets": [{"expr": "sovereignmap_active_nodes", "legendFormat": "Active Nodes", "refId": "A"}]
    },
