      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "#90EE90", "value": null}, {"color": "#FFED6F", "value": 0}, {"color": "#FF5733", "value": -1}]}, "decimals": 2, "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}},
      "targets": [{"expr": "(sovereignmap_fl_accuracy - sovereignmap_fl_accuracy offset 1h) or vector(0)", "refId": "A"}]
