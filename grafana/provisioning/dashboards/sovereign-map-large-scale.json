      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "#FF5733", "value": null}, {"color": "#FDB462", "value": 0.5}, {"color": "#2ECC40", "value": 0.8}]}, "unit": "percentunit", "mappings": [{"type": "value", "options": {"1": {"text": "HEALTHY", "color": "#2ECC40"}, "0": {"text": "FAILED", "color": "#FF5733"}}}], "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}},
      "targets": [{"expr": "(sovereignmap_active_nodes > 0 and sovereignmap_consensus_health > 0.8) ? 1 : 0", "refId": "A"}]
    },
    {
      "id": 12,
      "type": "stat",
