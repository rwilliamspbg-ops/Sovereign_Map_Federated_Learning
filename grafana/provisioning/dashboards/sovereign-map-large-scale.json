      "gridPos": {"x": 0, "y": 11, "w": 12, "h": 9},
      "options": {"legend": {"calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"custom": {"lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "showPoints": "never"}, "unit": "percent", "min": 0, "max": 100}, "overrides": [{"matcher": {"id": "byName", "options": "CPU %"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#E74C3C"}}]}, {"matcher": {"id": "byName", "options": "Memory %"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#3498DB"}}]}]},
      "targets": [
        {"expr": "avg(rate(container_cpu_usage_seconds_total{image!=\"\"}[1m])) * 100", "legendFormat": "CPU %", "refId": "A"},
        {"expr": "avg((container_memory_usage_bytes{image!=\"\"} / container_memory_max_bytes) * 100)", "legendFormat": "Memory %", "refId": "B"}
