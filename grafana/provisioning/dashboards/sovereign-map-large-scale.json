      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "#2ECC40", "value": null}, {"color": "#FFED6F", "value": 1}, {"color": "#FDB462", "value": 5}, {"color": "#FF5733", "value": 10}]}, "unit": "short", "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}},
