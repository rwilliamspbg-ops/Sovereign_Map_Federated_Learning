# ============================================================================
# ALLOWED EXCEPTIONS (!) - Files to keep
# ============================================================================

# Keep these critical files
!.github/
!.github/workflows/
!config/*.yml
!config/*.yaml
!config/examples/
!documentation/
!scripts/
!tests/fixtures/
!terraform/examples/
!docker/

# ============================================================================
# PATTERN RULES
# ============================================================================

# Ignore all files in certain directories
__pycache__/
.git/
.pytest_cache/
.mypy_cache/
.coverage/
htmlcov/

# But keep important config examples
!**/.env.example
!**/config.example.yml
!**/terraform.tfvars.example
